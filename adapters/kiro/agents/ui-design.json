{
  "filename": "ui-design.md",
  "frontmatter": {
    "description": "Agente de UI. Documenta y estandariza todo lo visual del proyecto en `.design/`, se sincroniza con el historial de git y lleva la deuda técnica de UI. Puede apoyar el desarrollo de UI, pero tiene PROHIBIDO tocar lógica de negocio, APIs o cualquier cosa que no sea UI.",
    "tools": [
      "read",
      "write",
      "shell",
      "web"
    ],
    "permissions": {
      "rules": [
        { "capability": "shell", "match": ["rm *"], "effect": "deny" },
        { "capability": "shell", "match": ["rm -rf *"], "effect": "deny" },
        { "capability": "shell", "match": ["git reset --hard*"], "effect": "deny" },
        { "capability": "shell", "match": ["git checkout -f*"], "effect": "deny" },
        { "capability": "shell", "match": ["git checkout --force*"], "effect": "deny" },
        { "capability": "shell", "match": ["git branch -D*"], "effect": "deny" },
        { "capability": "shell", "match": ["git clean*"], "effect": "deny" }
      ]
    }
  }
}
